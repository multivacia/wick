# Local persistent host collector env example (B5).
# Install to: $HOME/wick-r3e/config/r3e-collector.env   (Linux/macOS)
#         or: %USERPROFILE%\wick-r3e\config\r3e-collector.env  (Windows)
# Permissions: owner-only read/write (0600 / ACL restricted). NEVER commit real secrets.

PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Layout
WICK_ROOT=$HOME/wick-r3e
# App checkout lives at $WICK_ROOT/app
# Symlink app data/reports into durable roots (see local runbook)

# Prefer project venv
PATH=$HOME/wick-r3e/app/.venv/bin:/usr/local/bin:/usr/bin:/bin

# run-cycle wrapper optional knobs
# FU_AS_OF=
# FU_DRY_RUN_ONLY=0

# Optional Wick Settings names (not required for frozen binance/yahoo universe)
# LOG_LEVEL=INFO
# CANDLE_CLOSE_SAFETY_DELAY_SECONDS=30
# BRAPI_TOKEN=

# Alerts: local log until email configured
ALERT_MODE=LOCAL_LOG
# ALERT_EMAIL=
# EMAIL_TRANSPORT=mail
EMAIL_TRANSPORT_STATUS=DEFERRED
