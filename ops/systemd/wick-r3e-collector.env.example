# Example environment for HostGator VPS collector.
# Install to: /etc/wick/r3e-collector.env
# Permissions: root:root mode 0600
# NEVER commit real secrets. This file is an example only.

# --- process ---
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
# Ensure the project virtualenv is first on PATH
PATH=/srv/wick/app/.venv/bin:/usr/local/bin:/usr/bin:/bin

# --- layout (operational; code uses repo-relative paths via symlinks) ---
WICK_ROOT=/srv/wick
# Official store/reports live under durable paths and are symlinked into the app checkout:
#   /srv/wick/app/data/future_unseen -> /srv/wick/data/future_unseen
#   /srv/wick/app/reports/r3e_future_unseen -> /srv/wick/reports/r3e_future_unseen

# --- run-cycle wrapper (scripts/r3e_future_unseen_run_cycle.sh) ---
# FU_AS_OF=
# FU_DRY_RUN_ONLY=0

# --- optional Wick settings (pydantic Settings / .env names) ---
# Not required for frozen future-unseen universe (binance + yahoo public).
# LOG_LEVEL=INFO
# CANDLE_CLOSE_SAFETY_DELAY_SECONDS=30
# BRAPI_TOKEN=
# DATABASE_URL is NOT used by run-cycle (filesystem store only).

# --- email alerts (ops adapter; not read by wick.r3e.future_unseen) ---
ALERT_EMAIL=
# EMAIL_TRANSPORT=mail|sendmail|smtp
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# Do not put passwords in git. Keep them only in /etc/wick/r3e-collector.env on the host.
